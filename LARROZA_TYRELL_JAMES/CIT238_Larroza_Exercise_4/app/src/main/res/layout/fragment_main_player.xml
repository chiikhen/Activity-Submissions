<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainPlayer">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/listFragment"
        android:name="com.example.exercise_2_music_player.SongListFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/playerFragment"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_weight="5" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/playerFragment"
        android:name="com.example.exercise_2_music_player.PlayerFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/listFragment"
        app:layout_constraintVertical_weight="5" />

</androidx.constraintlayout.widget.ConstraintLayout>