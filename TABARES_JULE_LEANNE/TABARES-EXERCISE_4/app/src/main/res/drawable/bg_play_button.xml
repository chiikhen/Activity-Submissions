<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#4DEB9BC7" />
        </shape>
    </item>
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="90"
                android:startColor="#E94CB2"
                android:endColor="#CB3F9D"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
