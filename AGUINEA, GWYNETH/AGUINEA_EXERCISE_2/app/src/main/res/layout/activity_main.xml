<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/app-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_gray"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/songListContainer"
        android:name="com.example.exercise_2_music_player.SongListFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:layout="@layout/fragment_song_list" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/hotpink" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/playerContainer"
        android:name="com.example.exercise_2_music_player.PlayerFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:layout="@layout/fragment_player" />

</LinearLayout>